# Gitleaks — règles personnalisées
# Étend les règles par défaut (GCP SA keys, tokens, etc.)
title = "{{ project_name }} gitleaks config"

[extend]
useDefault = true  # conserve toutes les règles built-in

[[rules]]
id = "gcp-sa-key-json"
description = "GCP Service Account key"
regex = '''\"private_key\":\s*\"-----BEGIN RSA PRIVATE KEY-----'''
severity = "CRITICAL"
tags = ["gcp", "service-account"]

[[rules]]
id = "cloudflare-api-token"
description = "Cloudflare API Token"
regex = '''(?i)(cloudflare[_\-]?(api[_\-]?)?token[_\-]?=\s*['\"]?)([A-Za-z0-9_-]{40})'''
severity = "CRITICAL"
tags = ["cloudflare"]
